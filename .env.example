# ==========================================================================
# نمونه‌ی فایل تنظیمات محیطی (Environment Variables)
# ==========================================================================
# این فایل رو کپی کن و اسمش رو بذار ".env" و بعد مقدارهای واقعی خودت رو
# جای مقدارهای نمونه بذار. فایل .env هیچ‌وقت نباید توی گیت‌هاب آپلود بشه.
# روی هاست (Render) هم این مقدارها رو از پنل Environment Variables وارد
# می‌کنی، نه از طریق فایل.
# ==========================================================================

# آدرس اتصال به دیتابیس Postgres روی Supabase.
# از داشبورد پروژه‌ت، دکمه‌ی "Connect" رو بزن، بخش "Session pooler" رو
# انتخاب کن، لینکش رو کپی کن و به‌جای [YOUR-PASSWORD] رمز واقعی دیتابیستو
# بذار. توضیح کامل با عکس، توی README هست.
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-xxxxxxx.pooler.supabase.com:5432/postgres

# یک رشته‌ی طولانی و تصادفی، برای امضای امن کردن نشست‌های ورود کاربرا.
# برای ساختنش می‌تونی توی همون پنجره‌ی سیاه این دستور رو بزنی:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=یک-رشته-تصادفی-و-طولانی-اینجا-بذار

# دقیقاً همون نام کاربری‌ای که قراره باهاش ثبت‌نام کنی تا ادمین سایت بشی.
# این مقدار رو حتماً قبل از ثبت‌نام کردن با اون اسم تنظیم کن.
ADMIN_USERNAME=نام-کاربری-ادمین

# پورتی که سرور روش اجرا میشه (روی هاست‌های آنلاین معمولاً خودکار تنظیم میشه)
PORT=3000
